# ========================
# BOT CONFIGURATION
# ========================
BOT_TOKEN=your_telegram_bot_token_here

# Comma-separated list of admin Telegram user IDs
ADMIN_IDS=123456789,987654321
ADMIN_PASSWORD=your_admin_web_password_here
# Used to sign web admin session cookies. Use a long random string in production.
SESSION_SECRET=replace_with_long_random_secret
SESSION_COOKIE_SECURE=false
WEB_HOST=0.0.0.0
WEB_PORT=8000
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
AUDIT_LOG_PATH=logs/admin_audit.jsonl

# ========================
# DATABASE
# ========================
POSTGRES_USER=shopbot
POSTGRES_PASSWORD=shopbot_secret
POSTGRES_DB=shopbot
DATABASE_URL=postgresql+asyncpg://shopbot:shopbot_secret@db:5432/shopbot

# ========================
# REDIS
# ========================
REDIS_URL=redis://redis:6379/0

# ========================
# PAYMENT (Bank Transfer)
# ========================
BANK_NAME=Vietcombank
BANK_ACCOUNT_NO=0123456789
BANK_ACCOUNT_NAME=NGUYEN VAN A
# QR code template URL (optional, VietQR)
# VIETQR_URL=https://img.vietqr.io/image/{bank}-{account}-compact2.png

# ========================
# SHOP SETTINGS
# ========================
SHOP_NAME=Digital Shop
SHOP_SUPPORT_USERNAME=your_support_username
